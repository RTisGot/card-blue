  m_text: "\u30FB\u901A\u8DEF\u306F\u3064\u306A\u304C\u308B\u3088\u3046\u306B\u30AB\u30FC\u30C9\u3092\u51FA\u3059\u3002\uFF08\u30B9\u30BF\u30FC\u30C8\u30AB\u30FC\u30C9\u304B\u3089\u3064\u306A\u304C\u308C\u3070\u3069\u306E\u65B9\u5411\u306B\u9032\u3081\u3066\u3082OK\uFF09\n\u30AB\u30FC\u30C9\u306F\u6A2A\u5411\u304D\u306B\u7F6E\u3051\u306A\u3044\u306E\u3067\u6CE8\u610F\u3057\u3088\u3046\u3002\n\u30FB\u7834\u58CA\u30AB\u30FC\u30C9\u306F\u7F6E\u304B\u308C\u308B\u3068\u901A\u8DEF\u30AB\u30FC\u30C9\u304C\u7F6E\u3051\u306A\u304F\u306A\u308A\u307E\u3059\u3002\u89E3\u9664\u3059\u308B\u5834\u5408\u9053\u5177\u306E\u30A2\u30A4\u30B3\u30F3\u3068\u540C\u3058\u4FEE\u7406\u30AB\u30FC\u30C9\u304C\u4F7F\u7528\u3059\u308B\u304B\u8AB0\u304B\u306B\u4FEE\u7406\u3055\u308C\u308B\u307E\u3067\u6398\u308B\u4E8B\u304C\u51FA\u6765\u307E\u305B\u3093\u3002\n\u30FB\u843D\u77F3\u30AB\u30FC\u30C9\u306F\u901A\u8DEF\u53D6\u308A\u9664\u304D\u6368\u3066\u672D\u306B\u3057\u307E\u3059\u3002\n\u30FB\u5730\u56F3\u30AB\u30FC\u30C9\u306F\u30B4\u30FC\u30EB\u30AB\u30FC\u30C9\u3092\u898B\u308B\u3053\u3068\u304C\u3067\u304D\u305D\u308C\u3092\u4F1D\u3048\u3066\u3082\u4F1D\u3048\u306A\u304F\u3066\u3082OK\u5618\u3067\u3082\u304B\u307E\u308F\u306A\u3044\u3002"
